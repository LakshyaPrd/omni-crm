# Copy this file to .env.local and fill in your API keys

# ── Email Verification ────────────────────────────────────────────────────────

# Bouncer — Best accuracy (SMTP validation). Get key at: https://app.usebouncer.com/
# Without this, falls back to Abstract → DNS+MX heuristic
BOUNCER_API_KEY=your_bouncer_api_key_here

# Abstract API — Good accuracy, free tier (100 req/month): https://app.abstractapi.com/api/email-validation
ABSTRACT_API_KEY=your_abstract_api_key_here

# ── Job Search (Real Scraping) ─────────────────────────────────────────────────

# JSearch via RapidAPI — Searches LinkedIn, Indeed, Glassdoor, Naukri & more
# Get free key at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 200 requests/month
RAPIDAPI_KEY=your_rapidapi_key_here

# Adzuna — Global job board API, free registration: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# Note: Remotive (https://remotive.com/api) is always used as a free fallback
# for remote jobs — no key required.
